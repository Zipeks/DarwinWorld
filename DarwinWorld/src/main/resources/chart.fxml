<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="445.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="agh.presenter.ChartPresenter">
   <children>
      <VBox alignment="CENTER" layoutX="50.0">
         <children>
             <ChoiceBox fx:id="choiceBox" onAction="#onSeriesChange" prefWidth="150.0" VBox.vgrow="ALWAYS" />
            <LineChart fx:id="chart" prefHeight="400.0" prefWidth="518.0">
              <xAxis>
                <NumberAxis side="BOTTOM" style="-fx-tick-label-fill: black;" fx:id="xAxis" />
              </xAxis>
              <yAxis>
                <NumberAxis fx:id="yAxis" side="LEFT" style="-fx-tick-label-fill: black;" />
              </yAxis>
            </LineChart>
         </children>
         <padding>
            <Insets top="20.0" />
         </padding>
      </VBox>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</AnchorPane>

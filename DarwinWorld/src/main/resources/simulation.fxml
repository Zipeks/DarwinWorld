<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="agh.presenter.SimulationPresenter">
   <top>
      <HBox alignment="CENTER" maxHeight="-Infinity" prefHeight="90.0" prefWidth="200.0">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label fx:id="day" minWidth="150.0" prefWidth="140.0" text="Day 0 ">
                     <font>
                        <Font name="Fira Code Bold" size="24.0" />
                     </font>
                  </Label>
                  <Button fx:id="controlSimulation" minWidth="60.0" mnemonicParsing="false" onAction="#onPauseResumeClicked" prefWidth="60.0" style="-fx-background-color: #74aad3; -fx-border-width: 1; -fx-border-color: #000; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;" text="STOP">
                     <font>
                        <Font name="Fira Code Bold" size="12.0" />
                     </font>
                  </Button>

               </children>
               <padding>
                  <Insets right="20.0" />
               </padding>
            </HBox>
            <HBox alignment="CENTER_RIGHT" maxHeight="40.0" prefHeight="50.0" spacing="50.0" HBox.hgrow="ALWAYS">
               <children>
                  <HBox fx:id="animalsCountBox" alignment="CENTER_LEFT" minWidth="72.0" spacing="8.0">
                        <children>
                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/paw.png" />
                           </image>
                        </ImageView>
                        <Label fx:id="animalsCount" text="-" />
                     </children>
                  </HBox>
                  <HBox fx:id="grassCountBox" alignment="CENTER_LEFT" minWidth="72.0" spacing="8.0">
                     <children>
                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/tree.png" />
                           </image>
                        </ImageView>
                        <Label fx:id="grassCount" text="-" />
                     </children>
                  </HBox>
                  <HBox fx:id="emptyFieldsBox" alignment="CENTER_LEFT" minWidth="72.0" spacing="8.0">
                     <children>
                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/fields.png" />
                           </image>
                        </ImageView>
                        <Label fx:id="emptyFields" maxHeight="1.7976931348623157E308" text="-" />
                     </children>
                  </HBox>
                  <HBox fx:id="avgEnergyBox" alignment="CENTER_LEFT" minWidth="72.0" spacing="8.0">
                     <children>
                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/energy.png" />
                             </image>
                        </ImageView>
                        <Label fx:id="avgEnergy" text="-" />
                     </children>
                  </HBox>
                  <HBox fx:id="avgChildCountBox" alignment="CENTER_LEFT" minWidth="72.0" spacing="8.0">
                     <children>
                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/feeding-bottle.png" />
                           </image>
                        </ImageView>
                        <Label fx:id="avgChildCount" text="-" />
                     </children>
                  </HBox>
                  <HBox fx:id="avgAgeBox" alignment="CENTER_LEFT" minWidth="72.0" spacing="8.0">
                     <children>
                        <ImageView fx:id="avglifeExpectancy" fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/schedule.png" />
                           </image>
                        </ImageView>
                        <Label fx:id="avgAge" text="-" />
                     </children>
                  </HBox>
                  <HBox fx:id="genotypeBox" alignment="CENTER_LEFT" minWidth="300.0" spacing="8.0">
                     <children>
                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/dna.png" />
                           </image>
                        </ImageView>
                         <Label fx:id="genotype" text="-" />
                     </children>
                  </HBox>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <Canvas fx:id="mapCanvas" height="620.0" onMouseClicked="#onCanvasClicked" width="1280.0" />
   </center>
   <bottom>
      <HBox alignment="CENTER" spacing="50.0" style="-fx-background-color: #1e1e1e;" BorderPane.alignment="CENTER">
         <children>
            <HBox>
               <children>
                  <Label fx:id="dead" style="-fx-text-fill: PEACHPUFF;" text="☠">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label alignment="TOP_LEFT" layoutX="10.0" layoutY="10.0" style="-fx-text-fill: #e0e0e0;" text=": Animal is dead" textFill="WHITE">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox layoutX="10.0" layoutY="10.0">
               <children>
                  <Label fx:id="red" style="-fx-text-fill: RED;" text="🐻 ">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label layoutX="10.0" layoutY="10.0" style="-fx-text-fill: #e0e0e0;" text=": 1-3 moves" textFill="WHITE">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox layoutX="69.0" layoutY="10.0">
               <children>
                  <Label fx:id="yellow" alignment="CENTER" contentDisplay="CENTER" style="-fx-text-fill: YELLOW;" text="🐻 ">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label layoutX="10.0" layoutY="10.0" style="-fx-text-fill: #e0e0e0;" text=": 4-6 moves" textFill="WHITE">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox layoutX="128.0" layoutY="10.0">
               <children>
                  <Label fx:id="violet" style="-fx-text-fill: VIOLET;" text="🐻 ">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label layoutX="10.0" layoutY="10.0" style="-fx-text-fill: #e0e0e0;" text=": 7-9 moves" textFill="WHITE">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox layoutX="187.0" layoutY="10.0">
               <children>
                  <Label fx:id="peach" style="-fx-text-fill: PEACHPUFF;" text="🐻 ">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label layoutX="10.0" layoutY="10.0" style="-fx-text-fill: #e0e0e0;" text=": &gt; 10 moves" textFill="WHITE">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox layoutX="962.0" layoutY="10.0">
               <children>
                  <Label fx:id="cyan" style="-fx-text-fill: CYAN;" text="🐻 ">
                     <font>
                        <Font name="Noto Emoji" size="16.0" />
                     </font>
                  </Label>
                  <Label layoutX="10.0" layoutY="10.0" style="-fx-text-fill: #e0e0e0;" text=": The most popular genotype" textFill="WHITE">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox layoutX="848.0" layoutY="14.0">
               <children>
                  <Label fx:id="paws" style="-fx-text-fill: PEACHPUFF;" text="🐾">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label layoutX="10.0" layoutY="10.0" style="-fx-text-fill: #e0e0e0;" text=" : More than one animal on field" textFill="WHITE">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="4.0" top="4.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>

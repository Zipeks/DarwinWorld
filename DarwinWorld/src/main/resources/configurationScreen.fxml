<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="agh.presenter.ConfigurationPresenter">
   <center>
      <StackPane>
         <children>
            <ImageView fitHeight="427.0" fitWidth="705.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/bg4.png" />
               </image>
            </ImageView>
            <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="598.0" spacing="24.0">
               <children>
                  <HBox alignment="TOP_CENTER">
                     <children>
                        <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/title.png" />
                           </image>
                        </ImageView>
                     </children>
                  </HBox>
                  <HBox>
                     <VBox.margin>
                        <Insets top="16.0" />
                     </VBox.margin>
                     <children>
                        <HBox alignment="CENTER">
                           <children>
                              <Label alignment="CENTER" contentDisplay="CENTER" text="Podaj parametry startowe symulacji:">
                                 <font>
                                    <Font name="Fira Code Bold" size="14.0" />
                                 </font>
                              </Label>
                           </children>
                        </HBox>
                        <HBox alignment="TOP_RIGHT" HBox.hgrow="ALWAYS">
                           <children>
                              <Button fx:id="loadPreset" mnemonicParsing="false" onAction="#onLoadPresetClick" style="-fx-background-color: #74aad3; -fx-border-width: 1; -fx-border-color: #000; -fx-border-radius: 10; -fx-background-radius: 10;" text="Wczytaj preset">
                                 <font>
                                    <Font name="Fira Code Bold" size="12.0" />
                                 </font>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                  </HBox>
                  <GridPane hgap="16.0" vgap="24.0">
                    <columnConstraints>
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <VBox prefHeight="200.0" prefWidth="100.0">
                           <children>
                              <Label text="Rozmiar mapy (OX,OY)">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </Label>
                              <HBox spacing="5.0">
                                 <children>
                                    <TextField fx:id="initialMapWidth" text="10">
                                       <font>
                                          <Font name="Fira Code Regular" size="12.0" />
                                       </font>
                                    </TextField>
                                    <TextField fx:id="initialMapHeight" layoutX="10.0" layoutY="10.0" text="5">
                                       <font>
                                          <Font name="Fira Code Regular" size="12.0" />
                                       </font>
                                    </TextField>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox layoutX="10.0" layoutY="96.0" prefHeight="200.0" prefWidth="100.0" GridPane.columnIndex="1">
                           <children>
                              <Label text="Długość genomu">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="initialGenomLength" text="7">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>
                        <VBox layoutX="194.0" layoutY="4.0" prefHeight="200.0" prefWidth="100.0" GridPane.columnIndex="2">
                           <children>
                              <Label text="Liczba zwierząt">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="initialAnimals" text="1">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>
                        <VBox layoutX="10.0" layoutY="4.0" prefHeight="200.0" prefWidth="100.0" GridPane.rowIndex="1">
                           <children>
                              <Label text="Energia / po zjedzeniu">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </Label>
                              <HBox spacing="5.0">
                                 <children>
                                    <TextField fx:id="initialEnergy" text="10">
                                       <font>
                                          <Font name="Fira Code Regular" size="12.0" />
                                       </font>
                                    </TextField>
                                    <TextField fx:id="energyFromEatingGrass" layoutX="10.0" layoutY="10.0" text="4">
                                       <font>
                                          <Font name="Fira Code Regular" size="12.0" />
                                       </font>
                                    </TextField>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox layoutX="10.0" layoutY="4.0" prefHeight="200.0" prefWidth="100.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                           <children>
                              <Label text="Dzienna strata energii">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="energyLoss" text="1">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>
                        <VBox layoutX="10.0" layoutY="4.0" prefHeight="200.0" prefWidth="100.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
                           <children>
                              <Label text="Rozmnażanie (min,koszt)">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </Label>
                              <HBox spacing="5.0">
                                 <children>
                                    <TextField fx:id="fertilityEnergy" text="3">
                                       <font>
                                          <Font name="Fira Code Regular" size="12.0" />
                                       </font>
                                    </TextField>
                                    <TextField fx:id="reproductionCost" layoutX="10.0" layoutY="10.0" text="1">
                                       <font>
                                          <Font name="Fira Code Regular" size="12.0" />
                                       </font>
                                    </TextField>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox layoutX="10.0" layoutY="142.0" prefHeight="200.0" prefWidth="100.0" GridPane.rowIndex="2">
                           <children>
                              <Label text="Liczba roślin / przyrost">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </Label>
                              <HBox spacing="5.0">
                                 <children>
                                    <TextField fx:id="initialPlants" text="5">
                                       <font>
                                          <Font name="Fira Code Regular" size="12.0" />
                                       </font>
                                    </TextField>
                                    <TextField fx:id="dailyIncrease" layoutX="10.0" layoutY="10.0" text="2">
                                       <font>
                                          <Font name="Fira Code Regular" size="12.0" />
                                       </font>
                                    </TextField>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox layoutX="388.0" layoutY="96.0" prefHeight="200.0" prefWidth="100.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                           <children>
                              <Label text="Liczba mutacji (min,max)">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </Label>
                              <HBox spacing="5.0">
                                 <children>
                                    <TextField fx:id="mutationMin" text="0">
                                       <font>
                                          <Font name="Fira Code Regular" size="12.0" />
                                       </font>
                                    </TextField>
                                    <TextField fx:id="mutationMax" layoutX="10.0" layoutY="10.0" text="4">
                                       <font>
                                          <Font name="Fira Code Regular" size="12.0" />
                                       </font>
                                    </TextField>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox prefHeight="200.0" prefWidth="100.0" GridPane.columnIndex="2" GridPane.rowIndex="2">
                           <children>
                              <Label text="Długość dnia (ms)">
                                 <font>
                                    <Font name="Fira Code Regular" size="12.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="dayLength" text="1500" />
                           </children>
                        </VBox>
                     </children>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </GridPane>
                  <HBox>
                     <children>
                        <CheckBox fx:id="habsburg" mnemonicParsing="false" text="Klątwa Habsburgów" />
                        <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                           <children>
                              <Button fx:id="saveConfig" mnemonicParsing="false" onAction="#onSaveConfig" style="-fx-background-color: #e4854c; -fx-border-width: 1; -fx-border-color: #000; -fx-border-radius: 10; -fx-background-radius: 10;" text="Zapisz konfigurację">
                                 <font>
                                    <Font name="Fira Code Bold" size="12.0" />
                                 </font>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" VBox.vgrow="ALWAYS">
                     <children>
                        <Button fx:id="start" mnemonicParsing="false" onAction="#onStartClicked" style="-fx-background-color: #b7cd74; -fx-background-radius: 10; -fx-border-color: #000; -fx-border-radius: 10;" text="Uruchom symulację">
                           <font>
                              <Font name="Fira Code Bold" size="12.0" />
                           </font>
                           <padding>
                              <Insets bottom="8.0" left="24.0" right="24.0" top="8.0" />
                           </padding>
                        </Button>
                     </children>
                  </HBox>
               </children>
               <StackPane.margin>
                  <Insets />
               </StackPane.margin>
               <padding>
                  <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
               </padding>
            </VBox>
         </children>
      </StackPane>
   </center>
</BorderPane>
